# =============================================================================
# eviStream Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# === Application ===
ENVIRONMENT=development
DEBUG=true
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
REFRESH_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# === Supabase (PostgreSQL) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Optional: direct PostgreSQL connection for LangGraph checkpoints
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === AWS S3 (File Storage) ===
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=evistream-production

# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=your-gemini-key

# === Redis ===
REDIS_URL=redis://localhost:6380/0
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# === CORS / Frontend ===
# Set this to your EC2 public IP or domain (used for CORS allow-origin)
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# === Logging (Optional) ===
LOG_LEVEL=INFO
CLOUDWATCH_ENABLED=false
# CLOUDWATCH_LOG_GROUP=/evistream/development

# === Upload Limits ===
MAX_UPLOAD_SIZE=104857600

# === Local Storage Paths (optional — defaults work for EC2) ===
# CSV_OUTPUT_DIR=./outputs/eval_csvs
# JSON_OUTPUT_DIR=./outputs/eval_jsons
# NOTEBOOK_DIR=./storage/notebooks
# PDF_SOURCE_DIR=/data/pdfs
# MD_SOURCE_DIR=/data/markdowns
